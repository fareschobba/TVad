# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# JWT — rotate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<replace-with-fresh-secret>
JWT_EXPIRES_IN=24h

# CORS — comma-separated allowlist
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://tvad.onrender.com,https://cloud.aromamaster.tn

# Backblaze B2
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Misc
DEBUG=b2:*
