# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# JWT — rotate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<replace-with-fresh-secret>
JWT_EXPIRES_IN=24h

# CORS — comma-separated allowlist
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://tvad.onrender.com,https://cloud.aromamaster.tn

# Backblaze B2
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Misc
DEBUG=b2:*

# ─── Device state email alerts ───
# Master switch. Leave false until validated in staging, then flip per environment.
ALERTS_ENABLED=false
# Comma-separated OPS recipients.
ALERT_RECIPIENTS=support@aromamaster.tn,contact@aromamaster.tn
ALERT_SCAN_INTERVAL_SEC=60
ALERT_WARMUP_MINUTES=5
# Thresholds (minutes). Derived from the device 5-min heartbeat.
ALERT_OFFLINE_MINUTES=15
ALERT_STOPPED_MINUTES=12
ALERT_STUCK_MINUTES=10
# Quiet hours: no ENTER emails inside this window (recovery still allowed).
ALERT_QUIET_START=23:59
ALERT_QUIET_END=08:00
ALERT_QUIET_TZ=Africa/Tunis
# Send-rate safety cap.
ALERT_RATE_CAP=20
ALERT_RATE_WINDOW_MIN=10
# Per-rule toggles.
ALERT_RULE_OFFLINE_ENABLED=true
ALERT_RULE_STOPPED_ENABLED=true
ALERT_RULE_STUCK_ENABLED=true
# (SMTP_HOST/SMTP_PORT/SMTP_SECURE/SMTP_USER/SMTP_PASS/EMAIL_FROM already documented above.)
